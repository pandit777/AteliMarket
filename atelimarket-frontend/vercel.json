{
  "name": "atelimarket-frontend",
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "frontend/build"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "frontend/build/index.html"
    }
  ],
  "env": {
    "REACT_APP_API_URL": "https://atelimarket-backend.onrender.com/api/products",
    "REACT_APP_AUTH_URL": "https://atelimarket-backend.onrender.com/api/auth",
    "REACT_APP_IMAGE_URL": "https://atelimarket-backend.onrender.com/uploads"
  }
}